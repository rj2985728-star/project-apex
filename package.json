{
  "name": "project-apex",
  "version": "1.0.0",
  "description": "AI-powered investment research operating system",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "type-check": "tsc --noEmit",
    "db:migrate": "tsx src/database/migrations/run.ts",
    "db:reset": "tsx src/database/migrations/reset.ts"
  },
  "keywords": [
    "investment",
    "research",
    "trading",
    "quantitative",
    "fundamental",
    "technical"
  ],
  "author": "Project APEX",
  "license": "MIT",
  "dependencies": {
    "pg": "^8.11.3",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.1.2",
    "bcryptjs": "^2.4.3",
    "express-rate-limit": "^7.1.5",
    "redis": "^4.6.12"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "@types/node": "^20.10.6",
    "@types/express": "^4.17.21",
    "@types/pg": "^8.11.4",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/bcryptjs": "^2.4.6",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "prettier": "^3.1.1",
    "tsx": "^4.7.0"
  }
}
